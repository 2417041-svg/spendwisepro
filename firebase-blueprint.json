{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user financial settings and salary information",
      "type": "object",
      "properties": {
        "salary": {
          "type": "number",
          "description": "User's monthly salary"
        },
        "monthlyBudget": {
          "type": "number",
          "description": "User's planned monthly budget"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["salary", "monthlyBudget"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A single spending transaction",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "Amount spent"
        },
        "category": {
          "type": "string",
          "enum": ["Food", "Travel", "Shopping", "Bills", "Entertainment", "Health", "Other"],
          "description": "Category of expense"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of transaction"
        },
        "note": {
          "type": "string",
          "description": "Optional note"
        },
        "uid": {
          "type": "string",
          "description": "Owner's user ID"
        }
      },
      "required": ["amount", "category", "date", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Individual expense records"
    }
  }
}
